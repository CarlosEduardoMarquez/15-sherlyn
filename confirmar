<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Confirmación - XV Sherlyn</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;400;600&family=Great+Vibes&family=Cinzel:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --lila-glow: #bc9cff; --morado-deep: #05020a; --texto-púrpura: #a855f7; --glass-vibe: rgba(255, 255, 255, 0.04); }
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; font-family: 'Montserrat', sans-serif; background-color: var(--morado-deep); color: white; display: flex; justify-content: center; align-items: center; }
        
        #starfield { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; opacity: 0.6; }
        
        .glass-card { position: relative; z-index: 10; background: var(--glass-vibe); backdrop-filter: blur(30px); border: 1px solid rgba(188, 156, 255, 0.25); border-radius: 40px; padding: 35px 25px; width: 85%; max-width: 440px; text-align: center; box-shadow: 0 40px 100px rgba(0,0,0,0.8); max-height: 90vh; overflow-y: auto; scrollbar-width: none; -ms-overflow-style: none; }
        .glass-card::-webkit-scrollbar { display: none; }
        
        h1 { font-family: 'Great Vibes', cursive; font-size: clamp(3rem, 12vw, 4.5rem); color: var(--texto-púrpura); margin: 0; }
        
        .btn-action { display: inline-block; padding: 18px 45px; background: linear-gradient(135deg, #a855f7, #6b21a8); color: white; border-radius: 50px; text-decoration: none; font-weight: 600; margin-top: 15px; box-shadow: 0 15px 40px rgba(147, 51, 234, 0.4); transition: 0.3s; width: 100%; border: none; cursor: pointer; font-family: 'Montserrat', sans-serif; }
        .btn-action:disabled { opacity: 0.6; cursor: not-allowed; }
        .btn-decline { background: transparent; border: 1px solid #777; color: #ccc; margin-top: 10px; box-shadow: none; }
        .btn-decline:hover { background: rgba(255,255,255,0.05); color: white; border-color: white; }
        
        .instructions { background: rgba(255, 255, 255, 0.05); padding: 15px; border-radius: 15px; font-size: 0.85rem; color: #ddd; margin-bottom: 20px; border-left: 3px solid var(--lila-glow); text-align: left; line-height: 1.6; }
        .guest-slider { width: 100%; margin: 15px 0; accent-color: var(--lila-glow); cursor: pointer; height: 8px; border-radius: 5px; outline: none; }
    </style>
</head>
<body>
    <canvas id="starfield"></canvas>
    
    <div class="glass-card">
        <p style="letter-spacing: 6px; font-size: 0.7rem; color: #999; margin-bottom: 5px;">CONFIRMACIÓN VIP</p>
        <h1>Sherlyn Antonia</h1>
        <hr style="border: 0; border-top: 1px solid rgba(188, 156, 255, 0.2); margin: 20px 0;">
        
        <div id="loading-msg" style="color: #aaa; font-size: 0.9rem; letter-spacing: 1px; padding: 20px 0;">
            <i class="fas fa-spinner fa-spin" style="font-size: 2rem; color: var(--lila-glow); margin-bottom: 15px;"></i><br>
            Buscando tu invitación en la lista...
        </div>
        
        <div id="guest-details" style="display: none;">
            <div class="instructions">
                <i class="fas fa-info-circle" style="color: var(--lila-glow);"></i> <b style="color: white;">¿Cómo confirmar?</b><br>
                1. Desliza la barra lila para elegir cuántos asistirán.<br>
                2. Presiona "Confirmar" o "No asistiré".
            </div>
            
            <h2 id="guest-name" style="font-family: 'Cinzel', serif; font-size: clamp(1.3rem, 5vw, 1.8rem); line-height: 1.3; word-wrap: break-word; color: white; margin: 10px 0; font-weight: bold; text-shadow: 0 0 10px rgba(188, 156, 255, 0.5);">---</h2>
            <p style="color: var(--lila-glow); font-size: 0.9rem; margin-top: 0; letter-spacing: 1px;">Cupos en tu mesa: <span id="guest-limit" style="font-weight: bold; font-size: 1.2rem; color: white;">0</span></p>
            
            <div style="margin-top: 25px; padding: 15px; background: rgba(0,0,0,0.3); border-radius: 15px; border: 1px solid rgba(188, 156, 255, 0.2);">
                <label id="slider-label" style="font-size: 1.2rem; color: white; font-weight: bold; letter-spacing: 1px;">Asistentes: 0</label>
                <input type="range" id="guest-slider" class="guest-slider" min="0" max="0" value="0" 
                       oninput="document.getElementById('slider-label').innerText = 'Asistentes: ' + this.value">
            </div>
            
            <button id="btn-confirm" onclick="confirmarAsistencia(true)" class="btn-action">
                <i class="fas fa-check"></i> CONFIRMAR ASISTENCIA
            </button>
            <button id="btn-decline" onclick="confirmarAsistencia(false)" class="btn-action btn-decline">
                <i class="fas fa-times"></i> NO ASISTIRÉ
            </button>
        </div>

        <div id="success-msg" style="display: none; padding: 20px 0;"></div>
    </div>

    <script>
        // ====== FONDOS DE ESTRELLAS ======
        const c = document.getElementById('starfield'); const ctx = c.getContext('2d');
        function resize() { c.width = window.innerWidth; c.height = window.innerHeight; }
        window.addEventListener('resize', resize); resize();
        let stars = []; for(let i=0; i<100; i++) stars.push({ x:Math.random()*c.width, y:Math.random()*c.height, o:Math.random(), sp:Math.random()*0.01+0.005 });
        function drawStars() { ctx.clearRect(0,0,c.width,c.height); stars.forEach(s => { s.o += s.sp; if(s.o>1||s.o<0) s.sp*=-1; ctx.fillStyle=`rgba(188,156,255,${s.o})`; ctx.beginPath(); ctx.arc(s.x,s.y,1.5,0,Math.PI*2); ctx.fill(); }); requestAnimationFrame(drawStars); }
        drawStars();

        // ====== CONEXIÓN CON TU EXCEL ======
        const API_URL = "PEGA_AQUI_LA_MISMA_URL_DE_APPS_SCRIPT_QUE_USAS_EN_EL_INDEX"; 
        const urlParams = new URLSearchParams(window.location.search); const guestId = urlParams.get('id');

        if(guestId) {
            fetch(`${API_URL}?action=get_guest&id=${guestId}`)
            .then(res => res.json())
            .then(data => {
                if(data.encontrado) {
                    if(data.asistencia === "Confirmado" || data.asistencia === "No Asistirá") {
                        mostrarYaConfirmado(data.nombre, data.confirmados, data.asistencia);
                    } else {
                        mostrarFormulario(data.nombre, data.pases);
                    }
                } else {
                    document.getElementById('loading-msg').innerHTML = "<i class='fas fa-exclamation-triangle' style='color:#ef4444; font-size:2rem; margin-bottom:15px;'></i><br>Código no encontrado en la lista.";
                }
            }).catch(e => { document.getElementById('loading-msg').innerText = "Error al conectar con la base de datos."; });
        } else {
            document.getElementById('loading-msg').innerHTML = "Escanea el código QR de tu invitación física para confirmar.";
        }

        function mostrarFormulario(nombre, cupos) {
            document.getElementById('loading-msg').style.display = 'none';
            document.getElementById('guest-details').style.display = 'block';
            document.getElementById('guest-name').innerText = nombre;
            document.getElementById('guest-limit').innerText = cupos;
            const slider = document.getElementById('guest-slider');
            slider.max = cupos; slider.value = cupos;
            document.getElementById('slider-label').innerText = 'Asistentes: ' + cupos;
        }

        function mostrarYaConfirmado(nombre, cupos, estado) {
            document.getElementById('loading-msg').style.display = 'none';
            const msg = document.getElementById('success-msg'); msg.style.display = 'block';
            if(estado === "Confirmado") {
                msg.innerHTML = `<i class="fas fa-check-circle" style="color: var(--lila-glow); font-size: 3.5rem; margin-bottom: 15px;"></i><h2 style="font-family: 'Cinzel', serif; color: white; font-size: 1.5rem; margin: 0;">Asistencia Confirmada</h2><p style="color: #aaa; font-size: 0.9rem; margin-top: 10px;">Tu mesa está reservada para <b>${cupos} persona(s)</b>.</p>`;
            } else {
                msg.innerHTML = `<i class="fas fa-envelope-open" style="color: #777; font-size: 3.5rem; margin-bottom: 15px;"></i><h2 style="font-family: 'Cinzel', serif; color: white; font-size: 1.5rem; margin: 0;">Respuesta Registrada</h2><p style="color: #aaa; font-size: 0.9rem; margin-top: 10px;">Lamentamos que no nos acompañes.</p>`;
            }
        }

        function confirmarAsistencia(asiste) {
            const btnC = document.getElementById('btn-confirm'); const btnD = document.getElementById('btn-decline');
            const sliderVal = document.getElementById('guest-slider').value;
            const cuposConfirmados = asiste ? sliderVal : 0;
            
            if(asiste) btnC.innerHTML = '<i class="fas fa-spinner fa-spin"></i> GUARDANDO...';
            else btnD.innerHTML = '<i class="fas fa-spinner fa-spin"></i> PROCESANDO...';
            btnC.disabled = true; btnD.disabled = true;

            fetch(API_URL, { 
                method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ action: 'confirm_guest', id: guestId, confirmados: cuposConfirmados }) 
            }).then(() => {
                setTimeout(() => {
                    document.getElementById('guest-details').style.display = 'none';
                    mostrarYaConfirmado("", cuposConfirmados, asiste ? "Confirmado" : "No Asistirá");
                }, 1000);
            }).catch(e => {
                setTimeout(() => {
                    document.getElementById('guest-details').style.display = 'none';
                    mostrarYaConfirmado("", cuposConfirmados, asiste ? "Confirmado" : "No Asistirá");
                }, 1000);
            });
        }
    </script>
</body>
</html>
